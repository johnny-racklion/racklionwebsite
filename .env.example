# Optional endpoint that receives newsletter subscription payloads from the form.
# If omitted, the app runs in preview mode and stores the latest signup in localStorage.
VITE_NEWSLETTER_ENDPOINT=

# Optional endpoint that receives consultation inquiry payloads from the lead form.
# Use a serverless function, CRM webhook, or backend so provider secrets stay off the client.
VITE_LEAD_ENDPOINT=

# Optional scraper user agent for scheduled runs.
SCRAPER_USER_AGENT="RacklionOnPremSignal/0.1 (+https://example.com)"
